<% layout("/layouts/boilerplate") %>

<h3>All Listings</h3>
<div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 g-3">
  <% for (let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" style="text-decoration:none; color: inherit;">
        <div class="card col listing-card" 
        style="cursor: pointer;">
          <img src="<%= listing.image?.url || listing.imageURL %>" 
          class="card-img-top" 
          alt="listing_image"
           style="height: 20rem" >
           <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><strong><%= listing.title %></strong></b><br>
             ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> /night

            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>
